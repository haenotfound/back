generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//1. 스키마 정의
//2. dto

model Member {
  id              Int           @id @default(autoincrement())
  memberEmail     String        @unique
  memberName      String
  memberRole      MemberRole    @default(USER)
  memberNickname  String?
  memberProfile   String?
  memberIntro     String?
  memberInactive  Boolean?      @default(false)
  inactiveReason  String?
  memberCreateAt  DateTime      @default(now())
  socials         AuthAccount[]

  @@map("member")
}

enum MemberRole {
  USER
  ADMIN
}

model AuthAccount {
  id               Int          @id @default(autoincrement())
  memberProvider   AuthProvider
  memberProviderId String?
  memberPassword   String?
  memberId         Int
  member           Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberProviderId, memberId])
  @@map("tbl_auth_account")
}

enum AuthProvider {
  LOCAL
  GOOGLE
  KAKAO
  NAVER
}
